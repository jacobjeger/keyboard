<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/t9_status_bar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/t9_bar_height"
    android:orientation="horizontal"
    android:background="@color/keyboard_background"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <!-- Mode indicator (T9 / ABC / 123) -->
    <TextView
        android:id="@+id/t9_mode_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingEnd="8dp" />

    <!-- CAPS indicator -->
    <TextView
        android:id="@+id/caps_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CAPS"
        android:textColor="@color/accent_caps_lock"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:paddingEnd="8dp" />

    <!-- Current composing word -->
    <TextView
        android:id="@+id/t9_compose_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/key_text"
        android:textSize="@dimen/t9_compose_text_size"
        android:singleLine="true" />

    <!-- Letter options for current key -->
    <TextView
        android:id="@+id/t9_letter_options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/key_text_secondary"
        android:textSize="@dimen/t9_letters_text_size"
        android:paddingStart="8dp" />

</LinearLayout>
